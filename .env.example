# Database
DATABASE_URL="postgresql://hodon:hodon_secret@localhost:5432/hodon?schema=public"

# Auth secret — run `openssl rand -base64 32` to generate
AUTH_SECRET="change-me-to-a-random-secret-at-least-32-chars"

# App URL
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Upload directory (local filesystem for MVP)
UPLOAD_DIR="./uploads"

# Demo seed credentials
SEED_DEMO_EMAIL="demo@hodon.local"
SEED_DEMO_PASSWORD="demo1234"

# OpenAlex API key (optional fallback — can also be set per-user in /app/settings)
# Get yours at: https://openalex.org/
# OPENALEX_API_KEY="your-key-here"
