generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  FOUNDER
  PM
  RESEARCHER
  OTHER
}

enum InputType {
  OPENALEX_WORK
  PDF_UPLOAD
  URL
  QUESTION_TEXT
}

enum Domain {
  AI
  BIOTECH
  SPACE
  CLIMATE
  MATERIALS
  ECON
  OTHER
}

enum Objective {
  EXPLORE
  VALIDATE
  DESIGN_EXPERIMENT
  FIND_PRODUCT
}

enum ExperimentLevel {
  H48
  W2_4
  W8_12
}

enum ExperimentStatus {
  PENDING
  IN_PROGRESS
  DONE
}

enum ExperimentOutcome {
  SUCCESS
  FAIL
  INCONCLUSIVE
  NONE
}

enum ExportPreference {
  MD
  PDF
}

model User {
  id           String    @id @default(cuid())
  name         String
  email        String    @unique
  passwordHash String
  role         UserRole  @default(OTHER)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  inputs         Input[]
  outputs        Output[]
  savedSearches  SavedSearch[]
  settings       UserSettings?
  passwordResets PasswordReset[]
  projects       Project[]
}

model PasswordReset {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AccessRequest {
  id        String   @id @default(cuid())
  email     String
  role      String
  reason    String
  createdAt DateTime @default(now())
}

model Input {
  id             String    @id @default(cuid())
  userId         String
  type           InputType
  sourceRef      String
  rawText        String?
  domain         Domain    @default(OTHER)
  objective      Objective @default(EXPLORE)
  constraintsJson Json?
  createdAt      DateTime  @default(now())

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  outputs Output[]
}

model Output {
  id           String   @id @default(cuid())
  userId       String
  inputId      String
  title        String
  sectionsJson Json
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  input       Input        @relation(fields: [inputId], references: [id], onDelete: Cascade)
  experiments Experiment[]
  feedback    Feedback[]
}

model Experiment {
  id           String            @id @default(cuid())
  outputId     String
  level        ExperimentLevel
  title        String
  metricSuccess String
  status       ExperimentStatus  @default(PENDING)
  outcome      ExperimentOutcome @default(NONE)
  learning     String?
  nextStep     String?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  output Output @relation(fields: [outputId], references: [id], onDelete: Cascade)
}

model Feedback {
  id              String   @id @default(cuid())
  outputId        String
  sectionKey      String
  rating          Int
  missingEvidence String?
  createdAt       DateTime @default(now())

  output Output @relation(fields: [outputId], references: [id], onDelete: Cascade)
}

model SavedSearch {
  id          String   @id @default(cuid())
  userId      String
  query       String
  filtersJson Json?
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserSettings {
  id                String           @id @default(cuid())
  userId            String           @unique
  openAlexApiKey    String?
  exportPreference  ExportPreference @default(MD)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ── New models for Workspace (v2) ────────────────────────────────────────────

model Project {
  id            String    @id @default(cuid())
  userId        String
  title         String
  seedQuestion  String
  description   String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user    User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  chats   Chat[]
  nodes   CanvasNode[]
  edges   CanvasEdge[]
  sources Source[]
}

model Chat {
  id        String    @id @default(cuid())
  projectId String
  createdAt DateTime  @default(now())

  project  Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  messages Message[]
}

model Message {
  id        String   @id @default(cuid())
  chatId    String
  role      String   // "user" | "assistant"
  content   String   @db.Text
  rawJson   Json?    // SRF parsed if assistant response
  createdAt DateTime @default(now())

  chat  Chat         @relation(fields: [chatId], references: [id], onDelete: Cascade)
  nodes CanvasNode[]
}

model CanvasNode {
  id              String   @id @default(cuid())
  projectId       String
  parentMessageId String?
  type            String   // NodeType
  title           String
  contentSimple   String?  @db.Text
  contentMedium   String?  @db.Text
  contentSenior   String?  @db.Text
  epistemicStatus String?  // "fact"|"inference"|"hypothesis"|"speculation"
  positionX       Float    @default(0)
  positionY       Float    @default(0)
  metadata        Json?
  createdAt       DateTime @default(now())

  project       Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  parentMessage Message?       @relation(fields: [parentMessageId], references: [id])
  sourcesOn     NodeSource[]
  edgesFrom     CanvasEdge[]   @relation("EdgeSource")
  edgesTo       CanvasEdge[]   @relation("EdgeTarget")
}

model CanvasEdge {
  id           String  @id @default(cuid())
  projectId    String
  sourceNodeId String
  targetNodeId String
  relationType String  // RelationType
  metadata     Json?

  project    Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sourceNode CanvasNode @relation("EdgeSource", fields: [sourceNodeId], references: [id], onDelete: Cascade)
  targetNode CanvasNode @relation("EdgeTarget", fields: [targetNodeId], references: [id], onDelete: Cascade)
}

model Source {
  id         String   @id @default(cuid())
  projectId  String
  externalId String?  // OpenAlex ID
  sourceType String   // "paper"|"note"|"conversation"|"web"
  title      String
  abstract   String?  @db.Text
  url        String?
  authors    Json?    // string[]
  year       Int?
  metadata   Json?
  createdAt  DateTime @default(now())

  project   Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  nodesOn   NodeSource[]
}

model NodeSource {
  id          String @id @default(cuid())
  nodeId      String
  sourceId    String
  supportType String // "supports"|"contradicts"|"inspires"

  node   CanvasNode @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  source Source     @relation(fields: [sourceId], references: [id], onDelete: Cascade)
}
